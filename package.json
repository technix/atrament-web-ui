{
  "name": "@atrament/web-ui",
  "version": "2.5.0-dev",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "build-web": "vite build",
    "build-singlefile": "vite build --mode singlefile",
    "build-standalone": "vite build --mode standalone && node tools/build-standalone.mjs",
    "build-template": "vite build --mode singlefile -- --template",
    "build-android": "vite build --mode standalone && node tools/build-mobile.mjs",
    "build-ios": "vite build --mode standalone && node tools/build-mobile.mjs ios",
    "preview": "vite preview",
    "lint": "eslint --ext .jsx --ext js src",
    "compile-ink-script": "node tools/ink-compile.cjs",
    "install-inklecate": "node tools/install-inklecate.cjs",
    "download-google-font": "node tools/download-google-font.mjs",
    "update-neutralino": "cd tools/neutralino && npx neu update"
  },
  "dependencies": {
    "@atrament/web": "2.2.1",
    "@eo-locale/preact": "1.7.2",
    "@nanostores/preact": "1.1.0",
    "clsx": "2.1.1",
    "history": "5.3.0",
    "inkjs": "2.4.0",
    "mustache": "4.2.0",
    "normalize.css": "8.0.1",
    "preact": "10.29.2",
    "preact-router": "4.1.2",
    "seamless-scroll-polyfill": "2.3.4"
  },
  "devDependencies": {
    "@neutralinojs/neu": "11.7.1",
    "@preact/preset-vite": "2.10.5",
    "@stylistic/eslint-plugin": "5.10.0",
    "@terascope/fetch-github-release": "2.3.1",
    "@vite-pwa/assets-generator": "1.0.2",
    "dockerode": "5.0.0",
    "eslint": "9.39.3",
    "eslint-config-preact": "2.0.0",
    "google-fonts-helper": "3.7.4",
    "shelljs": "0.10.0",
    "vite": "8.0.14",
    "vite-plugin-clean-build": "1.4.1",
    "vite-plugin-html": "3.2.2",
    "vite-plugin-pwa": "1.3.0",
    "vite-plugin-singlefile": "2.3.3",
    "vite-plugin-zip-pack": "1.2.4",
    "zip-a-folder": "6.1.1"
  },
  "eslintConfig": {
    "extends": "preact"
  }
}
